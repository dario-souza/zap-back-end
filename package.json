{
  "name": "whats-back-end",
  "version": "1.0.0",
  "description": "back-end-api-whats",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "start:worker": "tsx src/workers/messageWorker.ts",
    "dev": "tsx --env-file .env src/server.ts",
    "dev:local": "tsx --env-file .env.local src/server.ts",
    "dev:worker": "tsx --env-file .env.local src/workers/messageWorker.ts",
    "dev:all": "npm run dev:local & npm run dev:worker",
    "redis:start": "docker compose -f docker-compose.local.yml up -d",
    "redis:stop": "docker compose -f docker-compose.local.yml down",
    "redis:logs": "docker logs zap-reminder-redis -f",
    "test:db": "tsx --env-file .env test-db.ts",
    "typecheck": "tsc --noEmit",
    "start:all": "npm run start:waha && sleep 5 && npm run dev",
    "start:waha": "docker compose -f docker-compose.waha.yml up -d",
    "stop:all": "docker compose -f docker-compose.waha.yml down",
    "logs:waha": "docker logs waha-api --tail 50 -f"
  },
  "author": "Dario de souza",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1"
  }
}
