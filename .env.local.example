# ============================================
# Desenvolvimento Local - Exemplo de configuração
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# ============================================
# Supabase (Cloud)
# ============================================
SUPABASE_URL=segredo
SUPABASE_ANON_KEY=segredo
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ============================================
# JWT
# ============================================
JWT_SECRET=sua-chave-jwt-aqui

# ============================================
# Frontend URL (local)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Redis Local
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# WAHA API (Cloud)
# ============================================
WAHA_URL=https://waha1.ux.net.br
WAHA_API_URL=http://localhost:3003
WAHA_API_KEY=global_434e50fe6adaac6f7450e23563ed457b
WAHA_SESSION_NAME=default

# ============================================
# Configuração
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# WhatsApp Anti-Bloqueio
# ============================================
# Delay mínimo entre mensagens POR USUÁRIO em milissegundos (recomendado: 2000-5000)
# Cada usuário terá seu próprio cooldown entre envios
WHATSAPP_MIN_DELAY_BETWEEN_MESSAGES=2000
# Delay máximo entre mensagens em milissegundos (recomendado: 5000-10000)
WHATSAPP_MAX_DELAY_BETWEEN_MESSAGES=5000
# Concorrência do worker (quantos jobs processa em paralelo)
# Recomendado: 10-20 paraprocessar múltiplos usuários em paralelo
WORKER_CONCURRENCY=10
