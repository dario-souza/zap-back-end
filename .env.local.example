# ============================================
# Desenvolvimento Local - Exemplo de configuração
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# ============================================
# Supabase (Cloud)
# ============================================
SUPABASE_URL=sua-url-supabase
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ============================================
# JWT
# ============================================
JWT_SECRET=sua-chave-jwt

# ============================================
# Redis Local
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# WAHA API
# ============================================
WAHA_URL=https://waha1.ux.net.br
WAHA_API_URL=https://waha1.ux.net.br
WAHA_API_KEY=sua-waha-api-key

# ============================================
# WAHA Webhook (para WAHA enviar eventos)
# ============================================
# Desenvolvimento local: URL do ngrok
# Producao: URL do seu backend
WAHA_WEBHOOK_URL=https://seu-ngrok.ngrok-free.dev/api/webhooks/waha

# ============================================
# WAHA WebSocket (URL do servidor WAHA)
# ============================================
# Local (dev): ws://localhost:3000/ws
# Producao: wss://seu-waha-server.com/ws
WAHA_WS_URL=ws://localhost:3000/ws

# ============================================
# Config
# ============================================
NODE_ENV=development
PORT=3001
