# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ============================================
# Database PostgreSQL (Supabase)
# ============================================
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ============================================
# JWT
# ============================================
JWT_SECRET=sua-chave-jwt-super-secreta-aqui

# ============================================
# Frontend URL
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# WAHA API Configuration
# ============================================

# Opção 1: WAHA Local (desenvolvimento)
# WAHA_API_URL=http://localhost:3003
# WAHA_API_KEY=chave-local-aqui

# Opção 2: WAHA PLUS Online (produção) ⭐ RECOMENDADO
# Use a URL fornecida pelo administrador da WAHA (com ou sem porta)
WAHA_API_URL=https://waha1.ux.net.br
WAHA_API_KEY=sua-api-key-da-waha-plus-aqui

WAHA_SESSION_NAME=default

# ============================================
# Webhook Configuration
# ============================================

# URL do webhook - será fornecido pelo Railway após o deploy
# Exemplo: https://zapreminder-production.up.railway.app/api/webhooks/waha
WAHA_WEBHOOK_URL=https://seu-backend-online.com/api/webhooks/waha

# ============================================
# Credenciais do Dashboard WAHA (apenas local)
# ============================================
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=zapreminder123
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=zapreminder123

# ============================================
# Configurações de Produção
# ============================================
NODE_ENV=production
PORT=3001

# ============================================
# Configurações antigas (DEPRECATED)
# ============================================
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=sua-chave-api-aqui
# EVOLUTION_INSTANCE_NAME=zapreminder
